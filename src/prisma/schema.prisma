generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  timezone  String   @default("Europe/Paris")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Availability
  availabilityWindows Json?
  workSchedule        Json?
  commute             Json?

  // Enrichment (from onboarding extraction)
  preferred_session_length Int?    // minutes — how long user likes to work in one sitting
  communication_style      String? // "direct", "encouraging", "detailed"
  userNotes                Json?   // append-only array: [{ "note": string, "extracted_at": string }]
  energy_peak              String? // "morning" | "afternoon" | "evening" — when user is most productive

  // Relations
  projects    Project[]
  discussions Discussion[]
  tasks       Task[]

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  goals       String?
  status      String   @default("active") // active, paused, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Extracted constraints from onboarding conversation
  // Stores: schedule_duration_weeks, blocked_time, available_time, preferences, exclusions
  contextData Json?

  // Enrichment (from onboarding extraction)
  target_deadline         DateTime? // extracted from conversation
  skill_level            String?   // "beginner", "intermediate", "advanced"
  tools_and_stack        String[]  @default([]) // e.g. ["Next.js", "Supabase", "Cursor"]
  project_type           String?   // "web app", "mobile app", "SaaS", "content", "script/automation", "other"
  weekly_hours_commitment Int?     // hours per week the user commits
  task_preference        String?  // "quick_wins" | "deep_focus" | "mixed" — how user likes to work
  motivation             String?   // one-sentence why they're building this — drives coaching tone
  phases                 Json?     // { phases: [{ id, title, goal, deadline, status }], active_phase_id }; status: completed|active|future
  // Append-only array of observations: [{ "note": string, "extracted_at": string }]
  projectNotes    Json?
  // How many schedule generations have occurred
  generationCount Int      @default(1)
  // From schedule generation (Session 3)
  milestones            Json?   // array of milestone objects generated during schedule creation
  schedule_duration_days Int?   // how many days the schedule spans — more precise than weeks; TODO: move to Schedule/Batch model when Feature 8 (multi-generation) ships
  // First day of schedule; null = use default (tomorrow) in generate-schedule
  schedule_start_date   DateTime?

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  discussions Discussion[]

  @@map("projects")
}

model Discussion {
  id        String   @id @default(uuid())
  projectId String
  messages  Json     // Array of {role, content, timestamp}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Discussion type: "project" (post-onboarding chat), "onboarding", "task"
  type   String  @default("project")
  // Only set when type = "task" — references Task id
  taskId String?

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("discussions")
}

model Task {
  id          String   @id @default(uuid())
  projectId   String?
  userId      String

  // Task details
  title              String
  description        String?
  type               String   @default("project") // project, personal
  estimatedDuration  Int      // minutes
  successCriteria    Json?  // Array of {id, text, done}. Observable, testable outcome for task completion
  
  // Scheduling
  scheduledDate     DateTime?
  scheduledStartTime DateTime?
  scheduledEndTime   DateTime?
  // Flexible tasks: no fixed time, only boundary (e.g. "during work hours")
  window_start  String?   // boundary start e.g. '09:00'
  window_end    String?   // boundary end e.g. '17:30'
  is_flexible   Boolean   @default(false)
  
  // Status
  status      String    @default("pending") // pending, in_progress, completed, skipped
  completedAt DateTime?
  skippedAt   DateTime?
  
  // Metadata
  priority     Int       @default(3) // 1-5
  depends_on   String[]  @default([]) // task IDs this task depends on
  label        String?
  // Scheduling metadata (Session 4 — from task generation)
  energy_required String? // "high" | "medium" | "low" — cognitive load of the task
  preferred_slot  String? // "peak_energy" | "normal" | "flexible" — ideal window type
  
  // Feedback fields (Feature 3)
  actualDuration    Int?       // minutes — how long the task actually took
  durationAccuracy  String?    // "less" | "same" | "more" — completion feedback
  completionNotes   String?    // optional notes the user adds on completion
  skipReason        String?    // "too_tired" | "ran_out_time" | "task_unclear" | "not_priority" | "other"
  skipNotes         String?    // free text explanation for skip
  startedAt         DateTime?  // when user started working on this task
  
  // Batch tracking — which schedule generation created this task
  batchNumber       Int        @default(1)

  // Recurring (for personal tasks)
  recurring Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussions Discussion[]

  @@map("tasks")
}
