# Database
# Pooled connection for app runtime (use with pgbouncer for Supabase)
DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]?pgbouncer=true"

# Direct connection for Prisma migrations (avoids pooler TLS issues)
# Supabase: Database → Connection string → URI → "Direct connection" or Session (port 5432)
# Add ?sslmode=require if you get P1011 TLS errors
DIRECT_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=